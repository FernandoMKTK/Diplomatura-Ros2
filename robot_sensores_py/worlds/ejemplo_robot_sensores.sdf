<?xml version="1.0" ?>
<!--
  ============================================================================
  EJEMPLO DE CLASE — Sensores en Gazebo + integración con ROS 2 (Fortress)
  ============================================================================
  Es el MISMO robot diferencial de la clase pasada... pero ahora con SENTIDOS.
  La clase pasada el robot se MOVÍA; hoy aprende a PERCIBIR y a CONTARLE al
  resto del sistema (ROS 2) lo que ve.

  Le agregamos tres sensores, los tres "clásicos" de un robot móvil:
    - CÁMARA RGB   (type="camera")    -> ve color, como un ojo.
    - LIDAR 2D     (type="gpu_lidar") -> mide distancias alrededor (un anillo).
    - IMU          (type="imu")       -> siente aceleración y giro (oído interno).

  IDEA CLAVE de la clase:
    Un <sensor> es NATIVO de Gazebo: no sabe nada de ROS. Gazebo calcula la
    imagen / el rayo / el ruido y lo publica en un "gz topic". Para que ese
    dato llegue a ROS 2 usamos un PUENTE (ros_gz_bridge). Sensor = qué se mide;
    puente = cómo cruza ese dato a ROS 2.

  ¡OJO! Sin los SISTEMAS del mundo correctos, los sensores NO publican nada:
    - ignition-gazebo-sensors-system -> activa cámara y LIDAR (necesita render).
    - ignition-gazebo-imu-system     -> activa los sensores IMU.
  Esto es justo lo que en las diapositivas aparece como libgz-sensors-system.

  CÓMO EJECUTARLO (Gazebo Fortress):
    ign gazebo -r ejemplo_robot_sensores.sdf
    (la bandera -r arranca YA en marcha; si no, recuerda pulsar ▶ Play)

  VER LOS SENSORES DENTRO DE GAZEBO (sin ROS todavía):
    - Listar tópicos:        ign topic -l
    - Espiar el LIDAR:       ign topic -e -t /escaner
    - GUI: añade el plugin "Image Display" y elige /camara para ver la cámara.
    - GUI: añade "Visualize Lidar" y elige /escaner para ver los rayos.

  LLEVAR LOS SENSORES A ROS 2 (puente, en otra terminal):
    Ver el archivo INTEGRACION_ROS2.md de esta carpeta.
  ============================================================================
-->
<sdf version="1.8">
  <world name="mundo_sensores">

    <!-- Física: cada cuánto avanza el tiempo de simulación. -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <!-- ====== SISTEMAS DEL MUNDO ======================================= -->
    <!-- Motor de física: integra el movimiento de todos los cuerpos.      -->
    <plugin filename="ignition-gazebo-physics-system"
            name="ignition::gazebo::systems::Physics">
    </plugin>
    <!-- Procesa comandos del usuario (crear/borrar/mover modelos).        -->
    <plugin filename="ignition-gazebo-user-commands-system"
            name="ignition::gazebo::systems::UserCommands">
    </plugin>
    <!-- Difunde el estado de la escena a la GUI (para verlo en pantalla). -->
    <plugin filename="ignition-gazebo-scene-broadcaster-system"
            name="ignition::gazebo::systems::SceneBroadcaster">
    </plugin>

    <!-- ¡NUEVO! Sistema de SENSORES: sin esto la cámara y el LIDAR NO
         publican nada (necesitan renderizar la escena con ogre2). -->
    <plugin filename="ignition-gazebo-sensors-system"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ¡NUEVO! Sistema IMU: activa cualquier <sensor type="imu">. -->
    <plugin filename="ignition-gazebo-imu-system"
            name="ignition::gazebo::systems::Imu">
    </plugin>

    <!-- Luz tipo sol: ilumina y proyecta sombras (la cámara necesita luz). -->
    <light type="directional" name="sol">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Suelo: un plano infinito sobre el que rueda el robot. -->
    <model name="suelo">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane><normal>0 0 1</normal><size>100 100</size></plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ====== OBSTÁCULOS: algo que VER y MEDIR ========================= -->
    <!-- Sin obstáculos, la cámara ve gris y el LIDAR da "infinito". Estos
         objetos hacen que los sensores tengan algo que reportar.          -->

    <!-- Pared roja al frente del robot (la cámara la verá; el LIDAR la mide). -->
    <model name="pared_roja">
      <static>true</static>
      <pose>6 0 1 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.3 4 2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.3 4 2</size></box></geometry>
          <material>
            <ambient>0.8 0.1 0.1 1</ambient>
            <diffuse>0.8 0.1 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cilindro verde a un costado (otro eco para el LIDAR). -->
    <model name="cilindro_verde">
      <static>true</static>
      <pose>4 3 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.5</radius><length>1.0</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.5</radius><length>1.0</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.7 0.1 1</ambient>
            <diffuse>0.1 0.7 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ====== EL ROBOT (el mismo de la clase pasada) =================== -->
    <model name="robot_azul" canonical_link="chasis">
      <pose>0 0 0 0 0 0</pose>

      <!-- CHASIS: cuerpo principal. Aquí colgaremos los sensores. -->
      <link name="chasis">
        <pose relative_to="__model__">0.5 0 0.4 0 0 0</pose>

        <inertial>
          <mass>1.14395</mass>
          <inertia>
            <ixx>0.126164</ixx>
            <iyy>0.416519</iyy>
            <izz>0.481014</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>

        <visual name="visual">
          <geometry><box><size>2.0 1.0 0.5</size></box></geometry>
          <material>
            <ambient>0.0 0.0 1.0 1</ambient>
            <diffuse>0.0 0.0 1.0 1</diffuse>
            <specular>0.0 0.0 1.0 1</specular>
          </material>
        </visual>

        <collision name="collision">
          <geometry><box><size>2.0 1.0 0.5</size></box></geometry>
        </collision>

        <!-- ============================================================= -->
        <!-- SENSOR 1: CÁMARA RGB                                          -->
        <!-- Va en la cara delantera del chasis (+X local), mirando al     -->
        <!-- frente. El eje óptico de la cámara apunta por su +X.          -->
        <!-- ============================================================= -->
        <sensor name="camara_rgb" type="camera">
          <pose>1.0 0 0.2 0 0 0</pose>   <!-- al frente y un poco arriba -->
          <topic>camara</topic>          <!-- gz topic: /camara -->
          <update_rate>30</update_rate>  <!-- 30 imágenes por segundo -->
          <always_on>1</always_on>
          <visualize>true</visualize>
          <camera>
            <horizontal_fov>1.047</horizontal_fov>   <!-- ~60° de apertura -->
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>                <!-- color RGB de 8 bits -->
            </image>
            <clip>
              <near>0.1</near>   <!-- más cerca de 0.1 m no se ve -->
              <far>100</far>     <!-- más lejos de 100 m no se ve -->
            </clip>
          </camera>
        </sensor>

        <!-- ============================================================= -->
        <!-- SENSOR 2: LIDAR 2D (gpu_lidar)                                -->
        <!-- Va arriba del chasis. Barre un abanico horizontal alrededor   -->
        <!-- de su +X y devuelve la distancia a lo que toca cada rayo.     -->
        <!-- ============================================================= -->
        <sensor name="lidar_2d" type="gpu_lidar">
          <pose>0 0 0.4 0 0 0</pose>     <!-- sobre el techo del chasis -->
          <topic>escaner</topic>         <!-- gz topic: /escaner -->
          <update_rate>10</update_rate>  <!-- 10 barridos por segundo -->
          <always_on>1</always_on>
          <visualize>true</visualize>
          <lidar>
            <scan>
              <horizontal>
                <samples>360</samples>        <!-- 360 rayos por barrido -->
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>  <!-- -180° -->
                <max_angle>3.14159</max_angle>   <!-- +180° (vuelta completa) -->
              </horizontal>
              <vertical>
                <samples>1</samples>          <!-- 1 sola fila = LIDAR 2D -->
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
              </vertical>
            </scan>
            <range>
              <min>0.12</min>      <!-- distancia mínima medible -->
              <max>12.0</max>      <!-- distancia máxima medible -->
              <resolution>0.01</resolution>
            </range>
          </lidar>
        </sensor>

        <!-- ============================================================= -->
        <!-- SENSOR 3: IMU                                                 -->
        <!-- No "ve" nada: siente la aceleración lineal y la velocidad     -->
        <!-- angular del chasis. Le añadimos un poco de RUIDO para que se  -->
        <!-- parezca a un sensor real (un IMU perfecto no existe).         -->
        <!-- ============================================================= -->
        <sensor name="imu_sensor" type="imu">
          <pose>0 0 0 0 0 0</pose>       <!-- en el centro del chasis -->
          <topic>imu</topic>             <!-- gz topic: /imu -->
          <update_rate>100</update_rate> <!-- 100 muestras por segundo -->
          <always_on>1</always_on>
          <imu>
            <angular_velocity>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
            </angular_velocity>
            <linear_acceleration>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
            </linear_acceleration>
          </imu>
        </sensor>
      </link>

      <!-- RUEDA IZQUIERDA -->
      <link name="rueda_izquierda">
        <pose relative_to="chasis">-0.5 0.6 0 -1.5707 0 0</pose>
        <inertial>
          <mass>1</mass>
          <inertia>
            <ixx>0.145833</ixx>
            <iyy>0.145833</iyy>
            <izz>0.125</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.4</radius><length>0.2</length></cylinder></geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><cylinder><radius>0.4</radius><length>0.2</length></cylinder></geometry>
        </collision>
      </link>

      <!-- RUEDA DERECHA -->
      <link name="rueda_derecha">
        <pose relative_to="chasis">-0.5 -0.6 0 -1.5707 0 0</pose>
        <inertial>
          <mass>1</mass>
          <inertia>
            <ixx>0.145833</ixx>
            <iyy>0.145833</iyy>
            <izz>0.125</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><cylinder><radius>0.4</radius><length>0.2</length></cylinder></geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><cylinder><radius>0.4</radius><length>0.2</length></cylinder></geometry>
        </collision>
      </link>

      <!-- RUEDA LOCA (caster) -->
      <frame name="marco_caster" attached_to="chasis">
        <pose>0.8 0 -0.2 0 0 0</pose>
      </frame>
      <link name="caster">
        <pose relative_to="marco_caster"/>
        <inertial>
          <mass>1</mass>
          <inertia>
            <ixx>0.1</ixx><iyy>0.1</iyy><izz>0.1</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <visual name="visual">
          <geometry><sphere><radius>0.2</radius></sphere></geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><sphere><radius>0.2</radius></sphere></geometry>
        </collision>
      </link>

      <!-- ====== ARTICULACIONES (JOINTS) ====== -->
      <joint name="junta_rueda_izquierda" type="revolute">
        <parent>chasis</parent>
        <child>rueda_izquierda</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="junta_rueda_derecha" type="revolute">
        <parent>chasis</parent>
        <child>rueda_derecha</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name="junta_caster" type="ball">
        <parent>chasis</parent>
        <child>caster</child>
      </joint>

      <!-- ====== PLUGIN DE CONTROL (igual que la clase pasada) ======
           DiffDrive escucha velocidades en /cmd_vel y mueve las ruedas.
           Lo dejamos para poder PASEAR el robot y ver cómo cambian los
           datos de los sensores en tiempo real. -->
      <plugin filename="ignition-gazebo-diff-drive-system"
              name="ignition::gazebo::systems::DiffDrive">
        <left_joint>junta_rueda_izquierda</left_joint>
        <right_joint>junta_rueda_derecha</right_joint>
        <wheel_separation>1.2</wheel_separation>
        <wheel_radius>0.4</wheel_radius>
        <odom_publish_frequency>10</odom_publish_frequency>
        <topic>cmd_vel</topic>
      </plugin>

    </model>
  </world>
</sdf>
